# Server
PORT=5000

# Required DB connection values (modify for your machine)
DB_HOST=localhost
DB_PORT=9100
DB_NAME=stockpro_db
DB_USER=stockpro
DB_PASSWORD=CHANGE_ME

# Optional pool tuning
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000

# Auth
JWT_ISSUER=stockpro-api
JWT_AUDIENCE=stockpro-client
JWT_ACCESS_SECRET=CHANGE_ME_WITH_STRONG_RANDOM_SECRET
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800
JWT_SESSION_MAX_LIFETIME_SECONDS=2592000

# Auth rate limits
AUTH_RATE_LIMIT_LOGIN_WINDOW_MS=60000
AUTH_RATE_LIMIT_LOGIN_MAX=10
AUTH_RATE_LIMIT_REGISTER_WINDOW_MS=60000
AUTH_RATE_LIMIT_REGISTER_MAX=5
AUTH_RATE_LIMIT_REFRESH_WINDOW_MS=60000
AUTH_RATE_LIMIT_REFRESH_MAX=20
